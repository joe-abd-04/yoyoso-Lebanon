# ============================================================
# YOYOSO Lebanon — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored and must NEVER be committed.
# ============================================================
#
# Rule of thumb:
#   • NEXT_PUBLIC_*  → exposed to the browser (safe to be public).
#   • everything else → SERVER-ONLY secrets. Never prefix a secret with
#     NEXT_PUBLIC_, never import it into a 'use client' module.

# ── Supabase ────────────────────────────────────────────────
# Project URL and the public anon/publishable key (safe in the browser;
# Row Level Security governs what the anon/authenticated roles can do).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role / secret key. Bypasses ALL RLS — full admin access.
# SERVER ONLY. Used by lib/supabase/server.ts for privileged reads/writes and
# by the rate-limit/lockout RPCs. Exposing this to the browser is a critical hole.
SUPABASE_SECRET_KEY=

# ── Cloudflare Turnstile (CAPTCHA on auth forms) ────────────
# Site key renders the widget (public); secret key verifies tokens server-side.
# If unset: dev degrades gracefully, production FAILS CLOSED (rejects).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Email (deferred to launch — Resend) ─────────────────────
# Order-confirmation + contact-notification emails. Optional until launch;
# without it those sends are stubbed/skipped. SERVER ONLY.
RESEND_API_KEY=

# ── Analytics (optional) ────────────────────────────────────
# Google Analytics 4 measurement id. Inert/no-op when unset.
NEXT_PUBLIC_GA_ID=
